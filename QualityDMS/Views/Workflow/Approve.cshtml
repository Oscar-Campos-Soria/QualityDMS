@model QualityDMS.Models.ViewModels.ApprovalActionViewModel
@{
    ViewData["Title"] = $"Aprobar - {Model.DocumentCode} v{Model.VersionNumber}";
}

<h1>Revisión de documento</h1>
<p><strong>Documento:</strong> @Model.DocumentCode - @Model.DocumentTitle</p>
<p><strong>Versión:</strong> @Model.VersionNumber | <strong>Paso actual:</strong> @Model.StepName</p>
<hr />

<div class="row">
    <div class="col-md-7">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-file-earmark-text"></i> Documento a revisar
            </div>
            <div class="card-body text-center">
                @{
                    var extension = System.IO.Path.GetExtension(Model.FilePath).ToLower();
                    var iconClass = extension switch
                    {
                        ".pdf" => "bi bi-file-earmark-pdf text-danger",
                        ".docx" or ".doc" => "bi bi-file-earmark-word text-primary",
                        ".xlsx" or ".xls" => "bi bi-file-earmark-excel text-success",
                        ".pptx" or ".ppt" => "bi bi-file-earmark-ppt text-warning",
                        ".dwg" or ".dxf" => "bi bi-file-earmark-code text-info",
                        ".png" or ".jpg" or ".jpeg" => "bi bi-file-earmark-image text-secondary",
                        _ => "bi bi-file-earmark"
                    };
                }
                <i class="@iconClass" style="font-size: 5rem;"></i>
                <p class="mt-3">
                    <a href="@Url.Action("DownloadVersion", "Documents", new { versionId = Model.VersionId })" class="btn btn-outline-primary">
                        <i class="bi bi-download"></i> Descargar archivo
                    </a>
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <form asp-action="Approve" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="InstanceId" />
            <input type="hidden" asp-for="VersionId" />

            <div class="mb-3">
                <label asp-for="ActionType" class="form-label">Decisión</label>
                <select asp-for="ActionType" class="form-select" asp-items="Html.GetEnumSelectList<WorkflowActionType>()"></select>
                <span asp-validation-for="ActionType" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Comments" class="form-label">Comentarios (opcional)</label>
                <textarea asp-for="Comments" class="form-control" rows="4" placeholder="Observaciones, justificación, etc."></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="SignatureData" class="form-label">Firma digital (Base64)</label>
                <input asp-for="SignatureData" type="text" class="form-control" placeholder="Si usas firma, pégala aquí" />
                <small class="form-text text-muted">Opcional. Puedes dejar vacío si no se requiere.</small>
            </div>

            <div class="d-flex justify-content-between">
                <button type="submit" class="btn btn-success">Enviar decisión</button>
                <a asp-action="MyPendingApprovals" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}