@model List<QualityDMS.Models.ViewModels.PendingApprovalDto>
@{
    ViewData["Title"] = "Mis aprobaciones pendientes";
}

<h1><i class="bi bi-clock-history"></i> Tareas pendientes</h1>
<hr />

@if (!Model.Any())
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle"></i> No tienes tareas pendientes de aprobación.
    </div>
}
else
{
    <div class="row">
        <div class="col-md-12">
            <div class="list-group">
                @foreach (var item in Model)
                {
                    <a href="@Url.Action("Approve", "Workflow", new { instanceId = item.InstanceId })" class="list-group-item list-group-item-action">
                        <div class="d-flex w-100 justify-content-between">
                            <h5 class="mb-1">@item.DocumentCode - @item.DocumentTitle</h5>
                            <small class="@(item.IsOverdue ? "text-danger" : "text-muted")">
                                @(item.IsOverdue ? "VENCIDA" : $"Vence: {item.DueDate:dd/MM/yyyy}")
                            </small>
                        </div>
                        <p class="mb-1">
                            <strong>Versión:</strong> v@item.VersionNumber |
                            <strong>Paso:</strong> @item.StepName |
                            <strong>Solicitado por:</strong> @item.InitiatedBy
                        </p>
                        <small>Iniciado: @item.StartedAt.ToLocalTime():dd/MM/yyyy HH:mm</small>
                    </a>
                }
            </div>
        </div>
    </div>
}