@model DocumentDetailViewModel
@{
    ViewData["Title"] = $"{Model.Document.Code} - {Model.Document.Title}";
}

<div class="d-flex justify-content-between align-items-center">
    <h1>@Model.Document.Title <small class="text-muted">(v@Model.Document.CurrentVersion)</small></h1>
    <div>
        @if (Model.CanEdit)
        {
            <a asp-action="Edit" asp-route-id="@Model.Document.DocumentId" class="btn btn-warning">
                <i class="bi bi-pencil"></i> Editar metadatos
            </a>
        }
        @if (Model.CanUploadVersion)
        {
            <a asp-action="NewVersion" asp-route-id="@Model.Document.DocumentId" class="btn btn-secondary">
                <i class="bi bi-file-earmark-plus"></i> Nueva versión
            </a>
        }
        @if (Model.CanApprove && Model.PendingAction != null)
        {
            <a asp-action="Approve" asp-controller="Workflow"
                   asp-route-instanceId="@Model.PendingAction.InstanceId"
                   class="btn btn-success">
                <i class="bi bi-check-circle"></i> Revisar aprobación
            </a>
        }
        @if (Model.CanObsolete)
        {
            <button type="button" class="btn btn-danger"
                    data-bs-toggle="modal" data-bs-target="#obsoleteModal">
                <i class="bi bi-archive"></i> Marcar obsoleto
            </button>
        }
    </div>
</div>

<p>
    <strong>Código:</strong> @Model.Document.Code &nbsp;|&nbsp;
    <strong>Estado:</strong>
    <span class="@Model.Document.StatusBadgeClass">@Model.Document.StatusLabel</span>
</p>
<hr />

<div class="row">
    <!-- ── Columna izquierda ───────────────────────────── -->
    <div class="col-md-8">

        <h4>Información general</h4>
        <table class="table table-bordered">
            <tr>
                <th style="width:200px">Descripción</th>
                <td>@(Model.Document.Description ?? "Sin descripción")</td>
            </tr>
            <tr>
                <th>Categoría</th>
                <td>@Model.Document.Category?.Name</td>
            </tr>
            <tr>
                <th>Departamento</th>
                <td>@Model.Document.Department?.Name</td>
            </tr>
            <tr>
                <th>Propietario</th>
                <td>@Model.Document.Owner?.FullName</td>
            </tr>
            <tr>
                <th>Etiquetas</th>
                <td>@Model.Document.Tags</td>
            </tr>
            <tr>
                <th>Confidencial</th>
                <td>@(Model.Document.IsConfidential ? "Sí" : "No")</td>
            </tr>
            <tr>
                <th>Próxima revisión</th>
                <td>@(Model.Document.NextReviewDate?.ToString("dd/MM/yyyy") ?? "No definida")</td>
            </tr>
            <tr>
                <th>Creado</th>
                <td>@Model.Document.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
            <tr>
                <th>Última actualización</th>
                <td>@Model.Document.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
        </table>

        <!-- ── Historial de versiones ──────────────────── -->
        <h4 class="mt-4">Historial de versiones</h4>
        <div class="table-responsive">
            <table class="table table-sm table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Versión</th>
                        <th>Tipo</th>
                        <th>Fecha</th>
                        <th>Autor</th>
                        <th>Estado</th>
                        <th>Archivo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.Versions.OrderByDescending(v => v.VersionNumber))
                    {
                        <tr>
                            <td><strong>@v.VersionNumber</strong></td>
                            <td>@v.VersionType</td>
                            <td>@v.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                            <td>@v.Author?.FullName</td>
                            <td><span class="badge bg-secondary">@v.Status</span></td>
                            <td>
                                <a asp-action="Download"
                                       asp-route-id="@v.VersionId"
                                       class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-download"></i> Descargar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- ── Flujo de aprobación ─────────────────────── -->
        <h4 class="mt-4">Flujo de aprobación actual</h4>
        @if (Model.ActiveWorkflow != null)
        {
            var totalSteps = Model.ActiveWorkflow.Template?.Steps.Count ?? 1;
            var progress = (int)((double)Model.ActiveWorkflow.CurrentStep / totalSteps * 100);

            <p class="mb-1">Progreso: paso <strong>@Model.ActiveWorkflow.CurrentStep</strong> de <strong>@totalSteps</strong></p>
            <div class="progress mb-3" style="height:20px;">
                <div class="progress-bar bg-success" role="progressbar"
                     style="width:@progress%"
                     aria-valuenow="@progress" aria-valuemin="0" aria-valuemax="100">
                    @progress%
                </div>
            </div>

            @if (Model.WorkflowHistory.Any())
            {
                <ul class="list-group">
                    @foreach (var action in Model.WorkflowHistory.OrderBy(a => a.ActedAt))
                    {
                        var badgeClass = action.ActionType switch
                        {
                            WorkflowActionType.Aprobado => "bg-success",
                            WorkflowActionType.Rechazado => "bg-danger",
                            WorkflowActionType.SolicitoCambios => "bg-warning text-dark",
                            _ => "bg-secondary"
                        };
                        <li class="list-group-item">
                            <div class="d-flex justify-content-between">
                                <strong>@action.StepName</strong>
                                <span class="badge @badgeClass">@action.ActionType</span>
                            </div>
                            <small class="text-muted">
                                Por @action.Actor?.FullName
                                el @action.ActedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </small>
                            @if (!string.IsNullOrEmpty(action.Comments))
                            {
                                <br />
                            
                                <small><em>Comentario: @action.Comments</em></small>
                            }
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">Aún no hay acciones registradas en este flujo.</p>
            }
        }
        else
        {
            <p class="text-muted">No hay flujo activo para este documento.</p>
        }
    </div>

    <!-- ── Columna derecha ────────────────────────────── -->
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-file-earmark"></i> Archivo actual
            </div>
            <div class="card-body text-center">
                @{
                    var currentVersion = Model.Versions
                        .FirstOrDefault(v => v.VersionNumber == Model.Document.CurrentVersion);
                }
                @if (currentVersion != null)
                {
                    <i class="@currentVersion.FileIconClass" style="font-size:4rem;"></i>
                    <p class="mt-2 mb-1 fw-semibold">@currentVersion.OriginalFileName</p>
                    <p class="text-muted small">@currentVersion.FileSizeFormatted</p>
                    <a asp-action="Download"
                           asp-route-id="@currentVersion.VersionId"
                           class="btn btn-primary w-100">
                        <i class="bi bi-download"></i> Descargar
                    </a>
                }
                else
                {
                    <p class="text-muted">No hay archivo disponible</p>
                }
            </div>
        </div>

        @if (Model.PendingAction != null)
        {
            <div class="card mt-3 border-warning shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <i class="bi bi-clock"></i> Aprobación pendiente
                </div>
                <div class="card-body">
                    <p class="mb-1"><strong>Paso:</strong> @Model.PendingAction.StepName</p>
                    <p class="mb-1">
                        <strong>Vence:</strong>
                        <span class="@(Model.PendingAction.IsOverdue ? "text-danger fw-bold" : "")">
                            @Model.PendingAction.DueDate.ToLocalTime().ToString("dd/MM/yyyy")
                        </span>
                    </p>
                    @if (Model.CanApprove)
                    {
                        <a asp-action="Approve" asp-controller="Workflow"
                               asp-route-instanceId="@Model.PendingAction.InstanceId"
                               class="btn btn-success w-100 mt-2">
                            <i class="bi bi-check2-circle"></i> Tomar acción
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- ── Modal obsoleto ─────────────────────────────────────── -->
<div class="modal fade" id="obsoleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Obsolete" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Marcar documento como obsoleto</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="id" value="@Model.Document.DocumentId" />
                    <p>
                        ¿Está seguro que desea marcar este documento como <strong>Obsoleto</strong>?
                        Esta acción no se puede deshacer.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-archive"></i> Sí, marcar obsoleto
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
