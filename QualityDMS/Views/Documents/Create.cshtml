@model QualityDMS.Models.ViewModels.DocumentCreateViewModel
@{
    ViewData["Title"] = "Crear documento";
}

<h1><i class="bi bi-plus-circle"></i> Nuevo documento</h1>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Code" class="form-label"></label>
                <input asp-for="Code" class="form-control" placeholder="Ej: MAN-CAL-001" />
                <span asp-validation-for="Code" class="text-danger"></span>
                <small class="form-text text-muted">Formato: XXX-YYY-### (tres letras, guión, tres letras, guión, números)</small>
            </div>
            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <label asp-for="CategoryId" class="form-label"></label>
                    <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="DepartmentId" class="form-label"></label>
                    <select asp-for="DepartmentId" asp-items="Model.Departments" class="form-select"></select>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Tags" class="form-label"></label>
                <input asp-for="Tags" class="form-control" placeholder="calidad, procedimiento, iso" />
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsConfidential" class="form-check-input" />
                <label asp-for="IsConfidential" class="form-check-label"></label>
            </div>
            <div class="mb-3">
                <label asp-for="NextReviewDate" class="form-label"></label>
                <input asp-for="NextReviewDate" type="date" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="File" class="form-label"></label>
                <input asp-for="File" type="file" class="form-control" accept=".pdf,.docx,.doc,.xlsx,.xls,.pptx,.ppt,.dwg,.dxf,.png,.jpg,.jpeg,.tiff,.txt,.csv,.zip,.rar" />
                <span asp-validation-for="File" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ChangeLog" class="form-label"></label>
                <textarea asp-for="ChangeLog" class="form-control" rows="2" placeholder="Versión inicial, cambios realizados..."></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="WorkflowTemplateId" class="form-label"></label>
                <select asp-for="WorkflowTemplateId" asp-items="Model.WorkflowTemplates" class="form-select"></select>
            </div>
            <button type="submit" class="btn btn-primary">Crear documento</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}