@model WorkflowTemplate
@{
    ViewData["Title"] = "Eliminar plantilla";
}

<h1><i class="bi bi-trash"></i> Eliminar plantilla</h1>
<div class="alert alert-danger mt-3">
    <strong>¿Está seguro de que desea eliminar la plantilla "@Model.Name"?</strong>
    <p>Esta acción eliminará la plantilla y todos sus pasos asociados. No se podrá recuperar.</p>
</div>

<dl class="row">
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Descripción</dt>
    <dd class="col-sm-10">@(Model.Description ?? "—")</dd>
    <dt class="col-sm-2">Categoría</dt>
    <dd class="col-sm-10">@(Model.Category?.Name ?? "—")</dd>
    <dt class="col-sm-2">Pasos</dt>
    <dd class="col-sm-10">@(Model.Steps?.Count ?? 0)</dd>
    <dt class="col-sm-2">Activa</dt>
    <dd class="col-sm-10">@(Model.IsActive ? "Sí" : "No")</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="TemplateId" />
    <button type="submit" class="btn btn-danger">Sí, eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>