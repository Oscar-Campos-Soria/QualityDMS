@model IEnumerable<QualityDMS.Models.QualityAudit>
@{
    ViewData["Title"] = "Auditorías";
}

<h1><i class="bi bi-clipboard-check"></i> Auditorías</h1>
<hr />

<a asp-action="Create" class="btn btn-primary mb-3">
    <i class="bi bi-plus-circle"></i> Nueva auditoría
</a>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Código</th>
            <th>Título</th>
            <th>Tipo</th>
            <th>Departamento</th>
            <th>Auditor Líder</th>
            <th>Inicio planeado</th>
            <th>Estado</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var a in Model)
        {
            <tr>
                <td>@a.Code</td>
                <td>@a.Title</td>
                <td>@a.AuditType</td>
                <td>@a.Department?.Name</td>
                <td>@a.LeadAuditor?.FullName</td>
                <td>@a.PlannedStart.ToShortDateString()</td>
                <td>@a.Status</td>
                <td>
                    <a asp-action="Details" asp-route-id="@a.AuditId"
                           class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-eye"></i> Ver
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>