@model IEnumerable<QualityDMS.Models.Notification>
@{
    ViewData["Title"] = "Mis notificaciones";
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
    var unreadOnly = (bool)ViewBag.UnreadOnly;
}

<div class="d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-bell"></i> Notificaciones</h1>
    <div>
        <a asp-action="MarkAllAsRead" class="btn btn-sm btn-secondary">Marcar todas como leídas</a>
        <a asp-action="Index" asp-route-unreadOnly="@(!unreadOnly)" class="btn btn-sm btn-outline-primary">
            @(unreadOnly ? "Mostrar todas" : "Mostrar solo no leídas")
        </a>
    </div>
</div>
<hr />

@if (!Model.Any())
{
    <div class="alert alert-info">No hay notificaciones.</div>
}
else
{
    <div class="list-group">
        @foreach (var n in Model)
        {
            <div class="list-group-item @(n.IsRead ? "bg-light" : "bg-white border-start border-primary border-3")">
                <div class="d-flex justify-content-between">
                    <h5 class="mb-1">@n.Title</h5>
                    <small>@n.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                </div>
                <p class="mb-1">@n.Message</p>
                @if (!n.IsRead)
                {
                    <button class="btn btn-sm btn-outline-primary mark-read" data-id="@n.NotificationId">Marcar como leída</button>
                }
            </div>
        }
    </div>

    <!-- Paginación -->
    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-unreadOnly="@unreadOnly">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}

@section Scripts {
    <script>
        document.querySelectorAll('.mark-read').forEach(btn => {
            btn.addEventListener('click', async function () {
                const id = this.dataset.id;
                await fetch('@Url.Action("MarkAsRead", "Notifications")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(id)
                });
                this.closest('.list-group-item').classList.remove('bg-white', 'border-start-primary');
                this.closest('.list-group-item').classList.add('bg-light');
                this.remove();
            });
        });
    </script>
}