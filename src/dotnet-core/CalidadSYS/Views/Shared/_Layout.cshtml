<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QualityDMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root { --sidebar-width: 260px; }
        body { background-color: #f5f7fa; }
        #sidebar {
            width: var(--sidebar-width);
            min-height: 100vh;
            background: linear-gradient(180deg, #1a3a5c 0%, #0d2035 100%);
            position: fixed;
            top: 0; left: 0;
            z-index: 100;
            transition: width .3s;
        }
        #sidebar .brand {
            padding: 1.5rem 1.25rem 1rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        #sidebar .brand h5 { color: #fff; font-weight: 700; margin: 0; }
        #sidebar .brand small { color: rgba(255,255,255,.5); font-size: 0.7rem; }
        #sidebar .nav-label {
            color: rgba(255,255,255,.4);
            font-size: 0.65rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: .75rem 1.25rem .25rem;
        }
        #sidebar .nav-link {
            color: rgba(255,255,255,.7);
            padding: .55rem 1.25rem;
            border-radius: 0;
            display: flex;
            align-items: center;
            gap: .65rem;
            font-size: .875rem;
            transition: background .15s, color .15s;
        }
        #sidebar .nav-link:hover, #sidebar .nav-link.active {
            background: rgba(255,255,255,.12);
            color: #fff;
        }
        #sidebar .nav-link .bi { font-size: 1rem; min-width: 20px; }
        #sidebar .badge-pill {
            margin-left: auto;
            font-size: .65rem;
        }
        #main-content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
        }
        #topbar {
            background: #fff;
            border-bottom: 1px solid #e3e8ef;
            padding: .75rem 1.5rem;
            position: sticky;
            top: 0;
            z-index: 99;
        }
        .page-content { padding: 1.5rem; }
        .stat-card { border: none; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,.07); }
        .stat-card .icon-box {
            width: 48px; height: 48px;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem;
        }
        .table thead th { background: #f8f9fc; font-size: .8rem; font-weight: 600; text-transform: uppercase; letter-spacing: .5px; color: #6b7280; }
        .badge-draft { background: #e5e7eb; color: #374151; }
        .badge-pending { background: #fef3c7; color: #92400e; }
        .badge-approved { background: #d1fae5; color: #065f46; }
        .badge-rejected { background: #fee2e2; color: #991b1b; }
        .badge-obsolete { background: #e0e0e0; color: #555; }
        @@media (max-width: 768px) {
            #sidebar { width: 0; overflow: hidden; }
            #main-content { margin-left: 0; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <nav id="sidebar">
        <div class="brand">
            <h5><i class="bi bi-shield-check me-2"></i>QualityDMS</h5>
            <small>ISO 9001:2015</small>
        </div>

        <div class="nav-label mt-2">Principal</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
           asp-controller="Dashboard" asp-action="Index">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <div class="nav-label">Documentos</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Documents" ? "active" : "")"
           asp-controller="Documents" asp-action="Index">
            <i class="bi bi-file-earmark-text"></i> Documentos
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Approvals" ? "active" : "")"
           asp-controller="Approvals" asp-action="Index">
            <i class="bi bi-check2-circle"></i> Aprobaciones
            @if (ViewBag.PendingCount != null && (int)ViewBag.PendingCount > 0)
            {
                <span class="badge bg-warning text-dark badge-pill">@ViewBag.PendingCount</span>
            }
        </a>

        <div class="nav-label">Configuración</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Departments" ? "active" : "")"
           asp-controller="Departments" asp-action="Index">
            <i class="bi bi-building"></i> Departamentos
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")"
           asp-controller="Categories" asp-action="Index">
            <i class="bi bi-tags"></i> Categorías
        </a>
        @if (User.IsInRole("Admin") || User.IsInRole("QualityManager"))
        {
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "WorkflowTemplates" ? "active" : "")"
               asp-controller="WorkflowTemplates" asp-action="Index">
                <i class="bi bi-diagram-3"></i> Flujos de Aprobación
            </a>
        }

        <div class="nav-label">Auditoría</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Audits" ? "active" : "")"
           asp-controller="Audits" asp-action="Index">
            <i class="bi bi-clipboard-check"></i> Auditorías
        </a>

        @if (User.IsInRole("Admin") || User.IsInRole("QualityManager"))
        {
            <div class="nav-label">API</div>
            <a class="nav-link" href="/swagger" target="_blank">
                <i class="bi bi-code-slash"></i> Swagger API
            </a>
        }
    </nav>
}

<div id="main-content">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div id="topbar" class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <h6 class="mb-0 text-secondary">@ViewData["Title"]</h6>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="text-secondary small"><i class="bi bi-person-circle me-1"></i>@User.Identity?.Name</span>
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-box-arrow-right"></i> Salir
                    </button>
                </form>
            </div>
        </div>
    }

    <div class="page-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
