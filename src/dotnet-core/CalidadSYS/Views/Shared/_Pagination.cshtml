@model PaginationViewModel
@if (Model != null && Model.TotalPages > 1)
{
    var existing = Context.Request.Query
        .Where(q => !string.Equals(q.Key, "page", StringComparison.OrdinalIgnoreCase))
        .SelectMany(q => q.Value.Select(v => $"{q.Key}={Uri.EscapeDataString(v ?? "")}"));
    var basePath = Context.Request.Path;

    string PageUrl(int p)
    {
        var parts = existing.Concat([$"page={p}"]);
        return $"{basePath}?{string.Join("&", parts)}";
    }

    <div class="card-footer bg-white d-flex justify-content-between align-items-center">
        <small class="text-muted">
            Mostrando @((Model.Page - 1) * Model.PageSize + 1)–@(Math.Min(Model.Page * Model.PageSize, Model.TotalCount))
            de @Model.TotalCount
        </small>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                @if (Model.HasPreviousPage)
                {
                    <li class="page-item">
                        <a class="page-link" href="@PageUrl(Model.Page - 1)">&laquo;</a>
                    </li>
                }
                @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" href="@PageUrl(i)">@i</a>
                    </li>
                }
                @if (Model.HasNextPage)
                {
                    <li class="page-item">
                        <a class="page-link" href="@PageUrl(Model.Page + 1)">&raquo;</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
}
