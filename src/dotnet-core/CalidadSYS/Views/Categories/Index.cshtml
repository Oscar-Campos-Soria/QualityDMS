@model IEnumerable<QualityDMS.Domain.Entities.DocumentCategory>
@{
    ViewData["Title"] = "Categorías de Documentos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold">Categorías de Documentos</h5>
    @if (User.IsInRole("Admin") || User.IsInRole("QualityManager"))
    {
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i> Nueva Categoría
        </a>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>Categoría Padre</th>
                    <th>Estado</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td><span class="badge bg-light text-dark border">@cat.Code</span></td>
                        <td class="fw-semibold">@cat.Name</td>
                        <td class="small text-muted">@(cat.ParentCategory?.Name ?? "-")</td>
                        <td>
                            <span class="badge @(cat.IsActive ? "badge-approved" : "badge-obsolete")">
                                @(cat.IsActive ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td>
                            @if (User.IsInRole("Admin") || User.IsInRole("QualityManager"))
                            {
                                <div class="d-flex gap-1">
                                    <a asp-action="Edit" asp-route-id="@cat.CategoryId"
                                       class="btn btn-sm btn-outline-warning py-0 px-2">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@cat.CategoryId"
                                       class="btn btn-sm btn-outline-danger py-0 px-2">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No hay categorías registradas.</td></tr>
                }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("_Pagination", ViewBag.Pagination as PaginationViewModel)
</div>
