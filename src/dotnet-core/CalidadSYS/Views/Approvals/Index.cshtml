@model IEnumerable<QualityDMS.Application.Workflow.Queries.GetPendingApprovals.PendingApprovalDto>
@{
    ViewData["Title"] = "Aprobaciones Pendientes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold">Aprobaciones Pendientes</h5>
    <span class="badge bg-warning text-dark fs-6">@Model.Count() pendientes</span>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Título</th>
                    <th>Paso</th>
                    <th>Enviado</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge bg-light text-dark border">@item.DocumentCode</span></td>
                            <td class="fw-semibold">@item.DocumentTitle</td>
                            <td>
                                <span class="badge badge-pending">Paso @item.CurrentStep: @item.StepName</span>
                            </td>
                            <td class="small text-muted">@item.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <a asp-action="Review" asp-route-documentId="@item.DocumentId"
                                   class="btn btn-sm btn-primary">
                                    <i class="bi bi-check2-circle me-1"></i> Revisar
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <i class="bi bi-check-circle text-success" style="font-size:3rem"></i>
                            <p class="text-muted mt-2 mb-0">No hay aprobaciones pendientes.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
