@model ReviewApprovalViewModel
@{
    ViewData["Title"] = $"Revisar: {Model.DocumentCode}";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold">
                    <i class="bi bi-file-earmark-check me-2 text-primary"></i>
                    Revisión de Documento
                </h6>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3 text-muted small">Código</dt>
                    <dd class="col-sm-9"><span class="badge bg-light text-dark border">@Model.DocumentCode</span></dd>
                    <dt class="col-sm-3 text-muted small">Título</dt>
                    <dd class="col-sm-9 fw-semibold">@Model.DocumentTitle</dd>
                    <dt class="col-sm-3 text-muted small">Paso actual</dt>
                    <dd class="col-sm-9"><span class="badge badge-pending">@Model.StepName</span></dd>
                    <dt class="col-sm-3 text-muted small">Enviado el</dt>
                    <dd class="col-sm-9 small text-muted">@Model.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold">Decisión</h6>
            </div>
            <div class="card-body">
                <form asp-action="Review" method="post">
                    <input type="hidden" asp-for="DocumentId" />
                    <input type="hidden" asp-for="DocumentCode" />
                    <input type="hidden" asp-for="DocumentTitle" />
                    <input type="hidden" asp-for="CurrentStep" />
                    <input type="hidden" asp-for="StepName" />
                    <input type="hidden" asp-for="SubmittedAt" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="mb-3">
                        <label asp-for="Comments" class="form-label fw-semibold small"></label>
                        <textarea asp-for="Comments" class="form-control" rows="3"
                                  placeholder="Comentarios opcionales..."></textarea>
                    </div>

                    <div class="mb-3" id="rejectReasonDiv" style="display:none">
                        <label asp-for="RejectReason" class="form-label fw-semibold small text-danger"></label>
                        <textarea asp-for="RejectReason" class="form-control border-danger" rows="2"
                                  placeholder="Motivo del rechazo..."></textarea>
                        <span asp-validation-for="RejectReason" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" name="Action" value="Approve"
                                class="btn btn-success flex-fill"
                                onclick="document.getElementById('rejectReasonDiv').style.display='none'">
                            <i class="bi bi-check-circle me-2"></i>Aprobar
                        </button>
                        <button type="button" class="btn btn-danger flex-fill"
                                onclick="toggleReject()">
                            <i class="bi bi-x-circle me-2"></i>Rechazar
                        </button>
                    </div>

                    <div id="rejectSubmitDiv" style="display:none" class="mt-2">
                        <button type="submit" name="Action" value="Reject" class="btn btn-danger w-100">
                            <i class="bi bi-send me-1"></i> Confirmar Rechazo
                        </button>
                    </div>

                    <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">Cancelar</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleReject() {
            const d = document.getElementById('rejectReasonDiv');
            const s = document.getElementById('rejectSubmitDiv');
            const visible = d.style.display !== 'none';
            d.style.display = visible ? 'none' : 'block';
            s.style.display = visible ? 'none' : 'block';
        }
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
