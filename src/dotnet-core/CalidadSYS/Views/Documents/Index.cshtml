@model DocumentFilterViewModel
@{
    ViewData["Title"] = "Documentos";
    var result = ViewBag.Result as QualityDMS.Application.Common.Models.PagedResult<DocumentDto>;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold">Documentos</h5>
    @if (User.IsInRole("Admin") || User.IsInRole("QualityManager") || User.IsInRole("DocumentManager"))
    {
        <a href="/Documents/Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i> Nuevo Documento
        </a>
    }
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <input type="text" name="SearchTerm" value="@Model.SearchTerm"
                       placeholder="Buscar por código o título..." class="form-control form-control-sm" />
            </div>
            <div class="col-md-2">
                <select name="CategoryId" class="form-select form-select-sm">
                    <option value="">Todas las categorías</option>
                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.Value" selected="@(c.Value == Model.CategoryId?.ToString())">@c.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select name="DepartmentId" class="form-select form-select-sm">
                    <option value="">Todos los departamentos</option>
                    @foreach (var d in Model.Departments)
                    {
                        <option value="@d.Value" selected="@(d.Value == Model.DepartmentId?.ToString())">@d.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select name="Status" class="form-select form-select-sm">
                    <option value="">Todos los estados</option>
                    @foreach (DocumentStatus s in Enum.GetValues(typeof(DocumentStatus)))
                    {
                        <option value="@((int)s)" selected="@(Model.Status == s)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-sm btn-outline-primary w-100">
                    <i class="bi bi-search me-1"></i> Filtrar
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Título</th>
                        <th>Categoría</th>
                        <th>Departamento</th>
                        <th>Versión</th>
                        <th>Estado</th>
                        <th>Próxima Revisión</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (result?.Items.Any() == true)
                    {
                        @foreach (var doc in result.Items)
                        {
                            <tr>
                                <td><span class="badge bg-light text-dark border">@doc.Code</span></td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@doc.DocumentId"
                                       class="text-decoration-none fw-semibold">@doc.Title</a>
                                </td>
                                <td class="small text-muted">@doc.CategoryName</td>
                                <td class="small text-muted">@doc.DepartmentName</td>
                                <td class="small">@(doc.CurrentVersion ?? "-")</td>
                                <td>
                                    <span class="badge @GetStatusBadge(doc.Status)">@doc.StatusName</span>
                                </td>
                                <td class="small @(doc.NextReviewDate < DateTime.Today ? "text-danger fw-semibold" : "text-muted")">
                                    @(doc.NextReviewDate?.ToString("dd/MM/yyyy") ?? "-")
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@doc.DocumentId"
                                       class="btn btn-xs btn-outline-secondary btn-sm py-0 px-2">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                No se encontraron documentos.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (result != null)
    {
        @await Html.PartialAsync("_Pagination", new PaginationViewModel
        {
            Page = result.Page,
            PageSize = result.PageSize,
            TotalCount = result.TotalCount
        })
    }
</div>

@functions {
    string GetStatusBadge(DocumentStatus s) => s switch
    {
        DocumentStatus.Approved => "badge-approved",
        DocumentStatus.PendingApproval => "badge-pending",
        DocumentStatus.Rejected => "badge-rejected",
        DocumentStatus.Obsolete => "badge-obsolete",
        _ => "badge-draft"
    };
}
