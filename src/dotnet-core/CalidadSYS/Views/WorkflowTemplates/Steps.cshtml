@model WorkflowTemplateStepsViewModel
@{
    ViewData["Title"] = $"Pasos: {Model.TemplateName}";
}

<div class="d-flex align-items-center gap-2 mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary py-0 px-2">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h5 class="mb-0 fw-bold">
        <i class="bi bi-diagram-3 me-2 text-primary"></i>@Model.TemplateName
    </h5>
    <span class="badge @(Model.IsActive ? "badge-approved" : "badge-obsolete") ms-1">
        @(Model.IsActive ? "Activo" : "Inactivo")
    </span>
    <a asp-action="Edit" asp-route-id="@Model.WorkflowTemplateId"
       class="btn btn-sm btn-outline-warning ms-auto py-0 px-2">
        <i class="bi bi-pencil me-1"></i> Editar plantilla
    </a>
</div>

@if (!string.IsNullOrEmpty(Model.TemplateDescription))
{
    <p class="text-muted small mb-3">@Model.TemplateDescription</p>
}

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-2 d-flex align-items-center">
                <h6 class="mb-0 small fw-bold">Pasos del flujo</h6>
                <span class="badge bg-secondary ms-2">@Model.Steps.Count</span>
            </div>
            <div class="card-body p-0">
                @if (Model.Steps.Any())
                {
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th class="text-center" style="width:60px">Orden</th>
                                <th>Paso</th>
                                <th>Asignado a</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var step in Model.Steps.OrderBy(s => s.StepOrder))
                            {
                                <tr>
                                    <td class="text-center">
                                        <span class="badge bg-primary rounded-circle">@step.StepOrder</span>
                                    </td>
                                    <td>
                                        <div class="fw-semibold small">@step.StepName</div>
                                        @if (!string.IsNullOrEmpty(step.Description))
                                        {
                                            <div class="text-muted" style="font-size:.75rem">@step.Description</div>
                                        }
                                        @if (step.RequiresAllApprovers)
                                        {
                                            <span class="badge bg-info text-dark" style="font-size:.65rem">Todos deben aprobar</span>
                                        }
                                    </td>
                                    <td class="small text-muted">@step.AssignedDisplay</td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <a asp-action="EditStep" asp-route-stepId="@step.WorkflowStepId"
                                               class="btn btn-sm btn-outline-warning py-0 px-2" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="DeleteStep" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="stepId" value="@step.WorkflowStepId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-2"
                                                        onclick="return confirm('¿Eliminar el paso \'@step.StepName\'?')"
                                                        title="Eliminar">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-diagram-3 fs-2 d-block mb-2 opacity-25"></i>
                        Sin pasos. Agrega el primero desde el formulario.
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-2">
                <h6 class="mb-0 small fw-bold"><i class="bi bi-plus-circle me-1 text-success"></i>Agregar paso</h6>
            </div>
            <div class="card-body">
                <form asp-action="AddStep" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="NewStep.WorkflowTemplateId" />
                    <div class="row g-3">
                        <div class="col-8">
                            <label asp-for="NewStep.StepName" class="form-label fw-semibold small"></label>
                            <input asp-for="NewStep.StepName" class="form-control form-control-sm"
                                   placeholder="Ej. Revisión técnica" />
                            <span asp-validation-for="NewStep.StepName" class="text-danger small"></span>
                        </div>
                        <div class="col-4">
                            <label asp-for="NewStep.StepOrder" class="form-label fw-semibold small"></label>
                            <input asp-for="NewStep.StepOrder" class="form-control form-control-sm" type="number" min="1" max="99" />
                            <span asp-validation-for="NewStep.StepOrder" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="NewStep.Description" class="form-label fw-semibold small"></label>
                            <textarea asp-for="NewStep.Description" class="form-control form-control-sm" rows="2"
                                      placeholder="Opcional"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold small">Asignar a</label>
                            <div class="d-flex gap-3 mb-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="NewStep.AssignmentType"
                                           id="typeRole" value="role" checked
                                           onchange="toggleAssignment(this.value)" />
                                    <label class="form-check-label small" for="typeRole">Rol</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="NewStep.AssignmentType"
                                           id="typeUser" value="user"
                                           onchange="toggleAssignment(this.value)" />
                                    <label class="form-check-label small" for="typeUser">Usuario específico</label>
                                </div>
                            </div>
                            <div id="roleSelect">
                                <select asp-for="NewStep.AssignedRoleName" asp-items="Model.NewStep.Roles"
                                        class="form-select form-select-sm">
                                    <option value="">-- Seleccionar rol --</option>
                                </select>
                            </div>
                            <div id="userSelect" style="display:none">
                                <select asp-for="NewStep.AssignedUserId" asp-items="Model.NewStep.Users"
                                        class="form-select form-select-sm">
                                    <option value="">-- Seleccionar usuario --</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="NewStep.RequiresAllApprovers" class="form-check-input" />
                                <label asp-for="NewStep.RequiresAllApprovers" class="form-check-label small"></label>
                            </div>
                        </div>
                    </div>
                    <div class="mt-3">
                        <button type="submit" class="btn btn-success btn-sm w-100">
                            <i class="bi bi-plus-circle me-1"></i> Agregar paso
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function toggleAssignment(type) {
            document.getElementById('roleSelect').style.display = type === 'role' ? '' : 'none';
            document.getElementById('userSelect').style.display = type === 'user' ? '' : 'none';
        }
    </script>
}
