@model WorkflowStepViewModel
@{
    ViewData["Title"] = "Editar Paso";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 d-flex align-items-center gap-2">
                <a asp-action="Steps" asp-route-id="@Model.WorkflowTemplateId"
                   class="btn btn-sm btn-outline-secondary py-0 px-2">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h6 class="mb-0 fw-bold"><i class="bi bi-pencil me-2 text-warning"></i>Editar Paso</h6>
            </div>
            <div class="card-body">
                <form asp-action="EditStep" asp-route-stepId="@Model.WorkflowStepId" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                    <input type="hidden" asp-for="WorkflowTemplateId" />
                    <div class="row g-3">
                        <div class="col-8">
                            <label asp-for="StepName" class="form-label fw-semibold small"></label>
                            <input asp-for="StepName" class="form-control" />
                            <span asp-validation-for="StepName" class="text-danger small"></span>
                        </div>
                        <div class="col-4">
                            <label asp-for="StepOrder" class="form-label fw-semibold small"></label>
                            <input asp-for="StepOrder" class="form-control" type="number" min="1" max="99" />
                            <span asp-validation-for="StepOrder" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-semibold small"></label>
                            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold small">Asignar a</label>
                            <div class="d-flex gap-3 mb-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" asp-for="AssignmentType"
                                           id="typeRole" value="role"
                                           onchange="toggleAssignment(this.value)" />
                                    <label class="form-check-label small" for="typeRole">Rol</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" asp-for="AssignmentType"
                                           id="typeUser" value="user"
                                           onchange="toggleAssignment(this.value)" />
                                    <label class="form-check-label small" for="typeUser">Usuario específico</label>
                                </div>
                            </div>
                            <div id="roleSelect">
                                <select asp-for="AssignedRoleName" asp-items="Model.Roles" class="form-select">
                                    <option value="">-- Seleccionar rol --</option>
                                </select>
                            </div>
                            <div id="userSelect" style="display:none">
                                <select asp-for="AssignedUserId" asp-items="Model.Users" class="form-select">
                                    <option value="">-- Seleccionar usuario --</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="RequiresAllApprovers" class="form-check-input" />
                                <label asp-for="RequiresAllApprovers" class="form-check-label small"></label>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-save me-1"></i> Guardar
                        </button>
                        <a asp-action="Steps" asp-route-id="@Model.WorkflowTemplateId"
                           class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function toggleAssignment(type) {
            document.getElementById('roleSelect').style.display = type === 'role' ? '' : 'none';
            document.getElementById('userSelect').style.display = type === 'user' ? '' : 'none';
        }
        // init on load
        document.addEventListener('DOMContentLoaded', function () {
            const checked = document.querySelector('input[name="AssignmentType"]:checked');
            if (checked) toggleAssignment(checked.value);
        });
    </script>
}
