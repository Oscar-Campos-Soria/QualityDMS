@model WorkflowTemplateViewModel
@{
    ViewData["Title"] = "Editar Plantilla";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 d-flex align-items-center gap-2">
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary py-0 px-2">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h6 class="mb-0 fw-bold"><i class="bi bi-diagram-3 me-2 text-warning"></i>Editar Plantilla</h6>
            </div>
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@Model.WorkflowTemplateId" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Name" class="form-label fw-semibold small"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-semibold small"></label>
                            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-save me-1"></i> Guardar
                        </button>
                        <a asp-action="Steps" asp-route-id="@Model.WorkflowTemplateId" class="btn btn-outline-primary">
                            <i class="bi bi-diagram-3 me-1"></i> Ver pasos
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
