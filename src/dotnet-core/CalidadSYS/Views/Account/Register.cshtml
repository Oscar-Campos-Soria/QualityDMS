@model RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>QualityDMS - Registro</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #1a3a5c 0%, #0d2035 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 0;
        }
        .card { width: 100%; max-width: 500px; border: none; border-radius: 16px; box-shadow: 0 20px 60px rgba(0,0,0,.3); }
        .card-header { background: linear-gradient(135deg, #0f766e, #0891b2); border-radius: 16px 16px 0 0; padding: 1.75rem 2rem; color: white; }
        .form-control:focus, .form-select:focus { border-color: #0891b2; box-shadow: 0 0 0 .2rem rgba(8,145,178,.2); }
        .role-card {
            border: 2px solid #e5e7eb;
            border-radius: 10px;
            padding: .75rem 1rem;
            cursor: pointer;
            transition: all .15s;
        }
        .role-card:hover { border-color: #0891b2; background: #f0f9ff; }
        .role-card.selected { border-color: #0891b2; background: #e0f2fe; }
        .role-card.disabled { opacity: .45; cursor: not-allowed; }
        .role-icon { font-size: 1.4rem; }
    </style>
</head>
<body>
<div class="container">
    <div class="card mx-auto">
        <div class="card-header">
            <div class="d-flex align-items-center gap-3">
                <i class="bi bi-person-plus-fill fs-2"></i>
                <div>
                    <h5 class="mb-0 fw-bold">Crear cuenta</h5>
                    <small class="opacity-75">QualityDMS — ISO 9001:2015</small>
                </div>
            </div>
        </div>
        <div class="p-4">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <form asp-action="Register" method="post">
                <input type="hidden" asp-for="AdminExists" />

                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label asp-for="FirstName" class="form-label fw-semibold small"></label>
                        <input asp-for="FirstName" class="form-control" placeholder="Juan" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="LastName" class="form-label fw-semibold small"></label>
                        <input asp-for="LastName" class="form-control" placeholder="Pérez" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Email" class="form-label fw-semibold small"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="correo@empresa.com" autocomplete="email" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="Password" class="form-label fw-semibold small"></label>
                        <input asp-for="Password" class="form-control" type="password"
                               placeholder="Mín. 12 caracteres" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold small"></label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password"
                               placeholder="Repite" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Selector de rol -->
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Tipo de usuario</label>
                    <span asp-validation-for="Role" class="text-danger small d-block"></span>
                    <input type="hidden" asp-for="Role" id="roleInput" />

                    <div class="d-flex flex-column gap-2">

                        @{
                            var adminDisabled = Model.AdminExists;
                        }

                        <div class="role-card @(adminDisabled ? "disabled" : "")"
                             onclick="@(adminDisabled ? "" : "selectRole(this,'Admin')")">
                            <div class="d-flex align-items-center gap-3">
                                <span class="role-icon">👑</span>
                                <div>
                                    <div class="fw-semibold small">Administrador</div>
                                    <div class="text-muted" style="font-size:.75rem">
                                        Acceso total al sistema.
                                        @if (adminDisabled) { <span class="badge bg-danger ms-1">Ya existe</span> }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="role-card" onclick="selectRole(this,'QualityManager')">
                            <div class="d-flex align-items-center gap-3">
                                <span class="role-icon">🏆</span>
                                <div>
                                    <div class="fw-semibold small">Gestor de Calidad</div>
                                    <div class="text-muted" style="font-size:.75rem">Gestiona documentos, auditorías y flujos.</div>
                                </div>
                            </div>
                        </div>

                        <div class="role-card" onclick="selectRole(this,'DocumentManager')">
                            <div class="d-flex align-items-center gap-3">
                                <span class="role-icon">📄</span>
                                <div>
                                    <div class="fw-semibold small">Gestor de Documentos</div>
                                    <div class="text-muted" style="font-size:.75rem">Crea y edita documentos.</div>
                                </div>
                            </div>
                        </div>

                        <div class="role-card" onclick="selectRole(this,'Approver')">
                            <div class="d-flex align-items-center gap-3">
                                <span class="role-icon">✅</span>
                                <div>
                                    <div class="fw-semibold small">Aprobador</div>
                                    <div class="text-muted" style="font-size:.75rem">Aprueba o rechaza documentos en flujo.</div>
                                </div>
                            </div>
                        </div>

                        <div class="role-card selected" onclick="selectRole(this,'Viewer')">
                            <div class="d-flex align-items-center gap-3">
                                <span class="role-icon">👁️</span>
                                <div>
                                    <div class="fw-semibold small">Visualizador</div>
                                    <div class="text-muted" style="font-size:.75rem">Solo lectura.</div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <button type="submit" class="btn w-100 fw-semibold py-2"
                        style="background:#0891b2;color:white;border:none">
                    <i class="bi bi-person-check me-2"></i>Crear cuenta
                </button>
            </form>

            <div class="text-center mt-3">
                <a asp-action="Login" class="text-muted small">
                    <i class="bi bi-arrow-left me-1"></i>Ya tengo cuenta
                </a>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function selectRole(el, role) {
        document.querySelectorAll('.role-card').forEach(c => c.classList.remove('selected'));
        el.classList.add('selected');
        document.getElementById('roleInput').value = role;
    }
</script>
@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
</body>
</html>
