@model DashboardMetricsDto
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card p-3">
            <div class="d-flex align-items-center gap-3">
                <div class="icon-box bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-file-earmark-text"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Documentos</div>
                    <div class="fs-4 fw-bold">@Model.TotalDocuments</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card p-3">
            <div class="d-flex align-items-center gap-3">
                <div class="icon-box bg-success bg-opacity-10 text-success">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div>
                    <div class="text-muted small">Aprobados</div>
                    <div class="fs-4 fw-bold text-success">@Model.ApprovedDocuments</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card p-3">
            <div class="d-flex align-items-center gap-3">
                <div class="icon-box bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-hourglass-split"></i>
                </div>
                <div>
                    <div class="text-muted small">Pendientes</div>
                    <div class="fs-4 fw-bold text-warning">@Model.PendingApprovals</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card p-3">
            <div class="d-flex align-items-center gap-3">
                <div class="icon-box bg-info bg-opacity-10 text-info">
                    <i class="bi bi-percent"></i>
                </div>
                <div>
                    <div class="text-muted small">Cumplimiento</div>
                    <div class="fs-4 fw-bold text-info">@Model.ComplianceRate%</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card p-3">
            <div class="d-flex align-items-center gap-3">
                <div class="icon-box bg-secondary bg-opacity-10 text-secondary">
                    <i class="bi bi-pencil-square"></i>
                </div>
                <div>
                    <div class="text-muted small">Borradores</div>
                    <div class="fs-4 fw-bold">@Model.DraftDocuments</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card p-3">
            <div class="d-flex align-items-center gap-3">
                <div class="icon-box bg-danger bg-opacity-10 text-danger">
                    <i class="bi bi-archive"></i>
                </div>
                <div>
                    <div class="text-muted small">Obsoletos</div>
                    <div class="fs-4 fw-bold text-danger">@Model.ObsoleteDocuments</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card p-3">
            <div class="d-flex align-items-center gap-3">
                <div class="icon-box bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-calendar-x"></i>
                </div>
                <div>
                    <div class="text-muted small">Por Revisar</div>
                    <div class="fs-4 fw-bold text-warning">@Model.DocumentsForReview</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card p-3 h-100 d-flex flex-column justify-content-center align-items-center">
            <a href="/Documents/Create"
               class="btn btn-primary w-100 @(User.IsInRole("Admin") || User.IsInRole("QualityManager") || User.IsInRole("DocumentManager") ? "" : "disabled")">
                <i class="bi bi-plus-circle me-1"></i> Nuevo Documento
            </a>
            <a asp-controller="Approvals" asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">
                <i class="bi bi-check2-circle me-1"></i> Ver Aprobaciones
            </a>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h6 class="mb-0 fw-bold">Actividad Reciente</h6>
                <a asp-controller="Documents" asp-action="Index" class="btn btn-sm btn-outline-primary">Ver todo</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Título</th>
                                <th>Estado</th>
                                <th>Fecha</th>
                                <th>Usuario</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.RecentActivity)
                            {
                                <tr>
                                    <td><span class="badge bg-light text-dark border">@item.DocumentCode</span></td>
                                    <td class="small">@item.Title</td>
                                    <td>
                                        <span class="badge @GetStatusBadgeClass(item.Action)">@item.Action</span>
                                    </td>
                                    <td class="small text-muted">@item.Date.ToString("dd/MM/yyyy")</td>
                                    <td class="small text-muted">@item.User</td>
                                </tr>
                            }
                            @if (!Model.RecentActivity.Any())
                            {
                                <tr><td colspan="5" class="text-center text-muted py-3">Sin actividad reciente</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold">Documentos por Estado</h6>
            </div>
            <div class="card-body">
                @foreach (var item in Model.DocumentsByStatus)
                {
                    var pct = Model.TotalDocuments > 0 ? (double)item.Count / Model.TotalDocuments * 100 : 0;
                    <div class="mb-3">
                        <div class="d-flex justify-content-between small mb-1">
                            <span>@item.Status</span>
                            <span class="fw-semibold">@item.Count</span>
                        </div>
                        <div class="progress" style="height:8px">
                            <div class="progress-bar @GetProgressBarClass(item.Status)"
                                 style="width:@pct.ToString("F0")%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusBadgeClass(string status) => status switch
    {
        "Approved" => "badge-approved",
        "PendingApproval" => "badge-pending",
        "Rejected" => "badge-rejected",
        "Obsolete" => "badge-obsolete",
        _ => "badge-draft"
    };

    string GetProgressBarClass(string status) => status switch
    {
        "Approved" => "bg-success",
        "PendingApproval" => "bg-warning",
        "Rejected" => "bg-danger",
        "Obsolete" => "bg-secondary",
        _ => "bg-primary"
    };
}
