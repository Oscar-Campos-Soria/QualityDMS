@model IEnumerable<QualityDMS.Domain.Entities.QualityAudit>
@{
    ViewData["Title"] = "Auditorías de Calidad";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold">Auditorías de Calidad</h5>
    @if (User.IsInRole("Admin") || User.IsInRole("QualityManager"))
    {
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i> Nueva Auditoría
        </a>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Título</th>
                    <th>Departamento</th>
                    <th>Estado</th>
                    <th>Fecha Planificada</th>
                    <th>Hallazgos</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var audit in Model)
                {
                    <tr>
                        <td><span class="badge bg-light text-dark border">@audit.AuditCode</span></td>
                        <td class="fw-semibold">@audit.Title</td>
                        <td class="small text-muted">@audit.Department?.Name</td>
                        <td>
                            <span class="badge @GetAuditStatusBadge(audit.Status)">@audit.Status</span>
                        </td>
                        <td class="small">@audit.PlannedDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (audit.Findings.Any())
                            {
                                <span class="badge bg-warning text-dark">@audit.Findings.Count</span>
                            }
                            else
                            {
                                <span class="text-muted small">-</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@audit.AuditId"
                                   class="btn btn-sm btn-outline-secondary py-0 px-2">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (User.IsInRole("Admin") || User.IsInRole("QualityManager"))
                                {
                                    <a asp-action="Edit" asp-route-id="@audit.AuditId"
                                       class="btn btn-sm btn-outline-warning py-0 px-2">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            No hay auditorías registradas.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("_Pagination", ViewBag.Pagination as PaginationViewModel)
</div>

@functions {
    string GetAuditStatusBadge(QualityDMS.Domain.Enums.AuditStatus s) => s switch
    {
        QualityDMS.Domain.Enums.AuditStatus.InProgress => "badge-pending",
        QualityDMS.Domain.Enums.AuditStatus.Completed => "badge-approved",
        QualityDMS.Domain.Enums.AuditStatus.Cancelled => "badge-obsolete",
        _ => "badge-draft"
    };
}
