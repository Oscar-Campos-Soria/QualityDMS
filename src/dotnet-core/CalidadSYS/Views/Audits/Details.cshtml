@model QualityDMS.Domain.Entities.QualityAudit
@{
    ViewData["Title"] = $"Auditoría: {Model.AuditCode}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
    @if (User.IsInRole("Admin") || User.IsInRole("QualityManager"))
    {
        <a asp-action="Edit" asp-route-id="@Model.AuditId" class="btn btn-sm btn-warning">
            <i class="bi bi-pencil me-1"></i> Editar
        </a>
    }
</div>

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted small">Código</dt>
                    <dd class="col-sm-8"><span class="badge bg-light text-dark border">@Model.AuditCode</span></dd>
                    <dt class="col-sm-4 text-muted small">Título</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.Title</dd>
                    <dt class="col-sm-4 text-muted small">Departamento</dt>
                    <dd class="col-sm-8 small">@Model.Department?.Name</dd>
                    <dt class="col-sm-4 text-muted small">Estado</dt>
                    <dd class="col-sm-8">
                        <span class="badge @GetBadge(Model.Status)">@Model.Status</span>
                    </dd>
                    <dt class="col-sm-4 text-muted small">Planificada</dt>
                    <dd class="col-sm-8 small">@Model.PlannedDate.ToString("dd/MM/yyyy")</dd>
                    <dt class="col-sm-4 text-muted small">Ejecutada</dt>
                    <dd class="col-sm-8 small">@(Model.ExecutedDate?.ToString("dd/MM/yyyy") ?? "-")</dd>
                    <dt class="col-sm-4 text-muted small">Cerrada</dt>
                    <dd class="col-sm-8 small">@(Model.ClosedDate?.ToString("dd/MM/yyyy") ?? "-")</dd>
                    @if (!string.IsNullOrEmpty(Model.Summary))
                    {
                        <dt class="col-sm-4 text-muted small">Resumen</dt>
                        <dd class="col-sm-8 small">@Model.Summary</dd>
                    }
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-2">
                <h6 class="mb-0 small fw-bold">Hallazgos (@Model.Findings.Count)</h6>
            </div>
            @if (User.IsInRole("Admin") || User.IsInRole("QualityManager"))
            {
                <div class="card-body border-bottom pb-3">
                    <form asp-action="AddFinding" method="post">
                        <input type="hidden" name="AuditId" value="@Model.AuditId" />
                        <div class="row g-2">
                            <div class="col-md-3">
                                <select name="FindingType" class="form-select form-select-sm">
                                    <option value="NC">No Conformidad</option>
                                    <option value="OBS">Observación</option>
                                    <option value="OM">Oportunidad de Mejora</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <input name="Description" class="form-control form-control-sm"
                                       placeholder="Descripción del hallazgo..." required />
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="btn btn-sm btn-primary w-100">
                                    <i class="bi bi-plus"></i> Agregar
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            }
            <div class="card-body p-0">
                @if (Model.Findings.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Tipo</th>
                                <th>Descripción</th>
                                <th>Cerrado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var f in Model.Findings)
                            {
                                <tr>
                                    <td>
                                        <span class="badge @(f.FindingType == "NC" ? "badge-rejected" : f.FindingType == "OBS" ? "badge-pending" : "badge-draft")">
                                            @f.FindingType
                                        </span>
                                    </td>
                                    <td class="small">@f.Description</td>
                                    <td>
                                        @if (f.IsClosed)
                                        {
                                            <i class="bi bi-check-circle text-success"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-circle text-muted"></i>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted small p-3 mb-0">Sin hallazgos registrados.</p>
                }
            </div>
        </div>
    </div>
</div>

@functions {
    string GetBadge(QualityDMS.Domain.Enums.AuditStatus s) => s switch
    {
        QualityDMS.Domain.Enums.AuditStatus.InProgress => "badge-pending",
        QualityDMS.Domain.Enums.AuditStatus.Completed => "badge-approved",
        QualityDMS.Domain.Enums.AuditStatus.Cancelled => "badge-obsolete",
        _ => "badge-draft"
    };
}
