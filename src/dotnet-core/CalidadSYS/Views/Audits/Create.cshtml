@model AuditViewModel
@{
    ViewData["Title"] = "Nueva Auditoría";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold">
                    <i class="bi bi-clipboard-plus me-2 text-primary"></i>Nueva Auditoría
                </h6>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="AuditCode" class="form-label fw-semibold small"></label>
                            <input asp-for="AuditCode" class="form-control text-uppercase" placeholder="AUD-2026-001" />
                            <span asp-validation-for="AuditCode" class="text-danger small"></span>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="Title" class="form-label fw-semibold small"></label>
                            <input asp-for="Title" class="form-control" placeholder="Auditoría interna..." />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-semibold small"></label>
                            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DepartmentId" class="form-label fw-semibold small"></label>
                            <select asp-for="DepartmentId" asp-items="Model.Departments" class="form-select">
                                <option value="">-- Seleccionar departamento --</option>
                            </select>
                            <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PlannedDate" class="form-label fw-semibold small"></label>
                            <input asp-for="PlannedDate" class="form-control" type="date" />
                            <span asp-validation-for="PlannedDate" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i> Crear
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
