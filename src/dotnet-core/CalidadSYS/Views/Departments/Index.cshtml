@model IEnumerable<QualityDMS.Domain.Entities.Department>
@{
    ViewData["Title"] = "Departamentos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold">Departamentos</h5>
    @if (User.IsInRole("Admin") || User.IsInRole("QualityManager"))
    {
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i> Nuevo Departamento
        </a>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Responsable</th>
                        <th>Estado</th>
                        <th>Creado</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dept in Model)
                    {
                        <tr>
                            <td><span class="badge bg-light text-dark border">@dept.Code</span></td>
                            <td class="fw-semibold">@dept.Name</td>
                            <td class="small text-muted">@(dept.ManagerName ?? "-")</td>
                            <td>
                                @if (dept.IsActive)
                                {
                                    <span class="badge badge-approved">Activo</span>
                                }
                                else
                                {
                                    <span class="badge badge-obsolete">Inactivo</span>
                                }
                            </td>
                            <td class="small text-muted">@dept.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Details" asp-route-id="@dept.DepartmentId"
                                       class="btn btn-sm btn-outline-secondary py-0 px-2">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (User.IsInRole("Admin") || User.IsInRole("QualityManager"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@dept.DepartmentId"
                                           class="btn btn-sm btn-outline-warning py-0 px-2">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@dept.DepartmentId"
                                           class="btn btn-sm btn-outline-danger py-0 px-2">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                No hay departamentos registrados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @await Html.PartialAsync("_Pagination", ViewBag.Pagination as PaginationViewModel)
</div>
