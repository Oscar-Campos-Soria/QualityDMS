@model QualityDMS.Domain.Entities.Department
@{
    ViewData["Title"] = $"Departamento: {Model.Name}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
    @if (User.IsInRole("Admin") || User.IsInRole("QualityManager"))
    {
        <a asp-action="Edit" asp-route-id="@Model.DepartmentId" class="btn btn-sm btn-warning">
            <i class="bi bi-pencil me-1"></i> Editar
        </a>
    }
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-sm-3 text-muted small fw-semibold">Código</div>
            <div class="col-sm-9"><span class="badge bg-light text-dark border fs-6">@Model.Code</span></div>
            <div class="col-sm-3 text-muted small fw-semibold">Nombre</div>
            <div class="col-sm-9 fw-semibold">@Model.Name</div>
            <div class="col-sm-3 text-muted small fw-semibold">Descripción</div>
            <div class="col-sm-9 small">@(Model.Description ?? "-")</div>
            <div class="col-sm-3 text-muted small fw-semibold">Responsable</div>
            <div class="col-sm-9 small">@(Model.ManagerName ?? "-")</div>
            <div class="col-sm-3 text-muted small fw-semibold">Estado</div>
            <div class="col-sm-9">
                <span class="badge @(Model.IsActive ? "badge-approved" : "badge-obsolete")">
                    @(Model.IsActive ? "Activo" : "Inactivo")
                </span>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-2">
        <h6 class="mb-0 small fw-bold">Documentos del Departamento (@Model.Documents.Count)</h6>
    </div>
    <div class="card-body p-0">
        @if (Model.Documents.Any())
        {
            <table class="table table-sm mb-0">
                <thead><tr><th>Código</th><th>Título</th><th>Estado</th></tr></thead>
                <tbody>
                    @foreach (var doc in Model.Documents.Take(20))
                    {
                        <tr>
                            <td><a asp-controller="Documents" asp-action="Details" asp-route-id="@doc.DocumentId">@doc.Code</a></td>
                            <td class="small">@doc.Title</td>
                            <td><span class="badge badge-draft small">@doc.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted small p-3 mb-0">Sin documentos asociados.</p>
        }
    </div>
</div>
